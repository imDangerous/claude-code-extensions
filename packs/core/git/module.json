{
  "name": "git",
  "description": "Conventional Commits + gitmoji + optional ticket prefix (커밋 컨벤션 — 전 스택). 훅/린트 구현은 js/git-hooks(Node).",
  "deps": [],
  "husky": false,
  "questions": [
    { "key": "ticketPrefix", "type": "string", "default": "", "prompt": "티켓 prefix (없으면 Enter)", "flag": "ticket", "validate": "^[A-Za-z0-9]*$", "validateHint": "영문/숫자만 (예: RP) — 정규식 메타문자 불가" },
    { "key": "ticketRequired", "type": "bool", "default": false, "prompt": "티켓 필수?", "flag": "ticket-required" }
  ],
  "targets": [
    { "src": "rules/git.md", "dest": ".claude/rules/git.md", "kind": "doc" }
  ]
}
