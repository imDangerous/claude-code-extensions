    { "src": "settings.json", "dest": ".claude/settings.json", "kind": "settings", "blockId": "core/srs-gate", "enabledIf": "srsGate" },
    { "src": "srs.md", "dest": ".claude/rules/srs.md", "kind": "doc", "enabledIf": "srsGate" },
