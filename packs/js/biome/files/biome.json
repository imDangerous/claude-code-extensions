{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.next",
      "!**/build",
      "!**/coverage",
      "!**/playwright-report",
      "!**/test-results",
      "!**/.claude",
      "!commitlint.config.cjs",
      // Tailwind 지시어/생성 CSS를 Biome 포매터가 재포맷해 드리프트 유발 → CSS 제외(특히 v4 @theme)
      "!**/*.css",
      "!**/pnpm-lock.yaml"
    ]
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "formatWithErrors": false
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": { "indentWidth": 2 }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": { "preset": "recommended" },
      "correctness": {
        "preset": "recommended",
        "noUnusedImports": "error",
        "noUnusedVariables": "warn"
      },
      "style": {
        "noDefaultExport": "off",
        "useImportType": "error",
        "useNodejsImportProtocol": "error"
      },
      "suspicious": {
        "preset": "recommended",
        "noConsole": { "level": "error", "options": { "allow": [] } },
        "noExplicitAny": "error"
      },
      "complexity": { "preset": "none" }
    }
  },
  "overrides": [
    {
      "includes": ["**/tests/**/*", "**/e2e/**/*", "**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
      "linter": {
        "rules": {
          "suspicious": { "noConsole": "off", "noExplicitAny": "off" }
        }
      }
    },
    {
      "includes": [
        "**/scripts/**/*",
        "**/next.config.*",
        "**/tailwind.config.*",
        "**/postcss.config.*",
        "**/vitest.config.*"
      ],
      "linter": {
        "rules": {
          "suspicious": { "noConsole": "off" }
        }
      }
    },
    {
      // 정적 리스트형 컴포넌트가 많아 index를 key로 쓰는 패턴 의도적 허용
      "includes": ["src/components/**/*"],
      "linter": {
        "rules": {
          "suspicious": { "noArrayIndexKey": "off" }
        }
      }
    }
  ]
}
